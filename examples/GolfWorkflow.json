{
    "WORKFLOW": "GolfDW_Load_Workflow",
    "SYSTEM": "GolfDW",
    "SOURCE": "Kaggle",
    "WAREHOUSE": "COMPUTE_WH",
    "TASK_TIMEOUT": 3600000,
    "MAX_FAILURES": 3,
    "CONFIG": "{\"workflow\":\"GolfDW_Load_Workflow\",\"environment\":\"production\",\"source_path\":\"@golf_stage\"}",
    "CF_ID": null,
    "TASKS": [
        {
            "name": "tsk_import_files",
            "schedule": "USING CRON 0 2 * * * UTC",
            "is_root": true,
            "description": "Stage CSV files from external stage into raw tables",
            "steps": [
                {
                    "type": "lineage",
                    "description": "Stage → Raw table",
                    "source": "sisula.public.@golf_stage",
                    "target": "golf_raw.public.PlayerImport"
                },
                {
                    "type": "sql",
                    "description": "COPY into raw table from stage",
                    "lineage": {
                        "source": "sisula.public.@golf_stage",
                        "target": "golf_raw.public.PlayerImport"
                    },
                    "sql": "COPY INTO golf_raw.public.PlayerImport FROM @golf_stage FILE_FORMAT = csv_ff ON_ERROR = CONTINUE"
                },
                {
                    "type": "return_value",
                    "message": "import complete"
                }
            ],
            "state": "suspended"
        },
        {
            "name": "tsk_create_typed_tables",
            "description": "Create typed tables from raw import",
            "after": [
                {
                    "name": "tsk_import_files"
                }
            ],
            "steps": [
                {
                    "type": "proc",
                    "description": "Create destination tables",
                    "call": "golf_raw.sp_CreateTypedTables()"
                }
            ],
            "state": "suspended"
        },
        {
            "name": "tsk_load_players",
            "description": "Load Player entities",
            "after": [
                {
                    "name": "tsk_create_typed_tables"
                }
            ],
            "steps": [
                {
                    "type": "lineage",
                    "description": "Raw → DW",
                    "source": "golf_raw.public.PlayerImport",
                    "target": "golf_dw.public.lPL_Player"
                },
                {
                    "type": "sql",
                    "description": "Insert players into anchor",
                    "lineage": {
                        "source": "golf_raw.public.PlayerImport",
                        "target": "golf_dw.public.lPL_Player"
                    },
                    "sql": "INSERT INTO golf_dw.lPL_Player SELECT DISTINCT player_id, player_name FROM golf_raw.PlayerImport"
                },
                {
                    "type": "return_value",
                    "message": "players loaded"
                }
            ],
            "state": "suspended"
        },
        {
            "name": "tsk_load_stats",
            "description": "Load Statistic entities",
            "after": [
                {
                    "name": "tsk_create_typed_tables"
                }
            ],
            "steps": [
                {
                    "type": "lineage",
                    "description": "Raw → DW",
                    "source": "golf_raw.public.PlayerImport",
                    "target": "golf_dw.public.lST_Statistic"
                },
                {
                    "type": "sql",
                    "description": "Insert statistics into anchor",
                    "lineage": {
                        "source": "golf_raw.public.PlayerImport",
                        "target": "golf_dw.public.lST_Statistic"
                    },
                    "sql": "INSERT INTO golf_dw.lST_Statistic SELECT DISTINCT stat_id, stat_name FROM golf_raw.PlayerImport WHERE stat_id IS NOT NULL"
                },
                {
                    "type": "return_value",
                    "message": "stats loaded"
                }
            ],
            "state": "suspended"
        },
        {
            "name": "tsk_load_measurements",
            "description": "Load Measurement entities (depends on Players + Stats)",
            "after": [
                {
                    "name": "tsk_load_players"
                },
                {
                    "name": "tsk_load_stats"
                }
            ],
            "steps": [
                {
                    "type": "lineage",
                    "description": "Raw → DW",
                    "source": "golf_raw.public.PlayerImport",
                    "target": "golf_dw.public.lME_Measurement"
                },
                {
                    "type": "sql",
                    "description": "Insert measurements with FK resolution",
                    "lineage": {
                        "source": "golf_raw.public.PlayerImport",
                        "target": "golf_dw.public.lME_Measurement"
                    },
                    "sql": "INSERT INTO golf_dw.lME_Measurement SELECT m.measurement_id, p.PL_ID, s.ST_ID, m.value FROM golf_raw.PlayerImport m JOIN golf_dw.lPL_Player p ON p.player_id = m.player_id JOIN golf_dw.lST_Statistic s ON s.stat_id = m.stat_id"
                }
            ],
            "state": "suspended"
        }
    ]
}
